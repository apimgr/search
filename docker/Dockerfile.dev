# =============================================================================
# Dev/Debug Image - Same as production but runs binary in debug mode
# Tagged :devel — used for local development and debug sessions
# =============================================================================
# Per AI.md PART 26: builder MUST be casjaysdev/go:latest
FROM casjaysdev/go:latest AS builder

ARG TARGETARCH
ARG VERSION=dev
ARG BUILD_DATE
ARG COMMIT_ID
ARG OFFICIALSITE

WORKDIR /build

# Copy go.mod first for layer caching
COPY go.mod go.sum ./
RUN go mod download

# Copy source and build with debug info (no -s -w strip flags)
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} go build \
    -ldflags "-X 'github.com/apimgr/search/src/config.Version=${VERSION}' -X 'github.com/apimgr/search/src/config.CommitID=${COMMIT_ID}' -X 'github.com/apimgr/search/src/config.BuildDate=${BUILD_DATE}' -X 'github.com/apimgr/search/src/config.OfficialSite=${OFFICIALSITE}'" \
    -o /build/binary/search ./src

# =============================================================================
# Runtime Stage - Same as production but with debug mode enabled
# =============================================================================
FROM alpine:latest

ARG VERSION=dev
ARG BUILD_DATE
ARG COMMIT_ID
ARG LICENSE=MIT

LABEL maintainer="apimgr <apimgr@casjay.cc>" \
      org.opencontainers.image.vendor="apimgr" \
      org.opencontainers.image.title="search-devel" \
      org.opencontainers.image.description="Debug/development build of search"

LABEL org.opencontainers.image.licenses="${LICENSE}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${COMMIT_ID}"

# Same packages as production
RUN apk add --no-cache \
    git \
    curl \
    bash \
    tini \
    tor \
    tzdata

COPY --from=builder /build/binary/search /usr/local/bin/search
COPY docker/rootfs/ /
COPY docker/Dockerfile.dev /root/Dockerfile

RUN chmod 755 /usr/local/bin/*

# Debug mode enabled — verbose logging, detailed errors
ENV MODE=development \
    DEBUG=true \
    TZ=America/New_York \
    DATABASE_DIR=/data/db/sqlite

EXPOSE 80

STOPSIGNAL SIGRTMIN+3

HEALTHCHECK --start-period=10m --interval=5m --timeout=15s --retries=3 \
    CMD /usr/local/bin/search --status || exit 1

ENTRYPOINT [ "tini", "-p", "SIGTERM", "--", "/usr/local/bin/entrypoint.sh" ]
