{{define "public"}}
<!DOCTYPE html>
{{/* Per AI.md PART 31: Dynamic lang and dir for RTL support */}}
<html lang="{{default "en" .Lang}}" dir="{{default "ltr" .Dir}}" class="theme-{{default "dark" .Theme}}" data-theme-mode="{{default "dark" .ThemeMode}}">
<head>
    {{template "head" .}}
    {{block "extra_head" .}}{{end}}
</head>
<body class="public-page {{.Page}}-page">
    {{/* Skip link for keyboard navigation - WCAG 2.1 AA */}}
    <a href="#main-content" class="skip-link">{{t "accessibility.skip_to_main_content"}}</a>

    {{/* Public header */}}
    {{template "public/header" .}}

    {{/* Sub-header search bar (non-home pages) */}}
    {{template "public/subheader" .}}

    {{/* Public navigation */}}
    {{template "public/nav" .}}
    <main id="main-content" class="main-content" role="main">
        {{/* Announcements banners */}}
        {{template "announcements" .}}

        {{/* Flash messages */}}
        {{if .Flash}}
        <div class="flash flash-{{.Flash.Type}}" role="alert">
            {{.Flash.Message}}
            <button class="flash-close" aria-label="{{t "common.close"}}">&times;</button>
        </div>
        {{end}}

        {{/* Main content area */}}
        {{block "content" .}}{{end}}
    </main>

    {{/* Public footer */}}
    {{template "public/footer" .}}

    {{template "scripts" .}}
    {{block "extra_scripts" .}}{{end}}

    {{/* Cookie consent popup */}}
    {{template "cookie_consent" .}}
</body>
</html>
{{end}}
