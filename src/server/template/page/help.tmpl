{{define "content"}}
<div class="static-page help-page">
    <header class="help-header">
        <h1>{{t "help.title"}}</h1>
        <p class="subtitle">{{t "help.subtitle" (default (t "home.brand_fallback") .Config.Server.Branding.Title)}}</p>
    </header>

    {{if .Config.Server.Pages.Help.Content}}
    <div class="page-content markdown">
        {{.Config.Server.Pages.Help.Content | safe}}
    </div>
    {{else}}
    <div class="page-content">
        {{/* Table of Contents */}}
        <nav class="help-toc">
            <h2>{{t "help.toc.heading"}}</h2>
            <ul>
                <li><a href="#getting-started">{{t "help.toc.getting_started"}}</a></li>
                <li><a href="#search-categories">{{t "help.toc.search_categories"}}</a></li>
                <li><a href="#bang-commands">{{t "help.toc.bang_commands"}}</a></li>
                <li><a href="#direct-answers">{{t "help.toc.direct_answers"}}</a></li>
                <li><a href="#search-operators">{{t "help.toc.search_operators"}}</a></li>
                <li><a href="#keyboard-shortcuts">{{t "help.toc.keyboard_shortcuts"}}</a></li>
                <li><a href="#api-docs">{{t "help.toc.api_docs"}}</a></li>
                <li><a href="#privacy">{{t "help.toc.privacy"}}</a></li>
                {{if .Config.Server.Tor.Enabled}}<li><a href="#tor-access">{{t "help.toc.tor_access"}}</a></li>{{end}}
                <li><a href="#faq">{{t "help.toc.faq"}}</a></li>
            </ul>
        </nav>

        {{/* Getting Started */}}
        <section id="getting-started" class="help-section">
            <h2>{{t "help.getting_started.heading"}}</h2>
            <p>{{t "help.getting_started.intro_prefix" (default (t "home.brand_fallback") .Config.Server.Branding.Title)}} <kbd>Enter</kbd> {{t "help.getting_started.intro_suffix"}}</p>
            <p>{{t "help.getting_started.no_tracking"}}</p>
        </section>

        {{/* Search Categories */}}
        <section id="search-categories" class="help-section">
            <h2>{{t "help.categories.heading"}}</h2>
            <p>{{t "help.categories.intro"}}</p>
            <div class="category-grid">
                <div class="category-item">
                    <span class="category-icon">🌐</span>
                    <strong>{{t "help.categories.general.label"}}</strong>
                    <p>{{t "help.categories.general.description"}}</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">🖼️</span>
                    <strong>{{t "help.categories.images.label"}}</strong>
                    <p>{{t "help.categories.images.description"}}</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">🎬</span>
                    <strong>{{t "help.categories.videos.label"}}</strong>
                    <p>{{t "help.categories.videos.description"}}</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">📰</span>
                    <strong>{{t "help.categories.news.label"}}</strong>
                    <p>{{t "help.categories.news.description"}}</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">🗺️</span>
                    <strong>{{t "help.categories.maps.label"}}</strong>
                    <p>{{t "help.categories.maps.description"}}</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">📁</span>
                    <strong>{{t "help.categories.files.label"}}</strong>
                    <p>{{t "help.categories.files.description"}}</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">🎵</span>
                    <strong>{{t "help.categories.music.label"}}</strong>
                    <p>{{t "help.categories.music.description"}}</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">💻</span>
                    <strong>{{t "help.categories.it.label"}}</strong>
                    <p>{{t "help.categories.it.description"}}</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">📚</span>
                    <strong>{{t "help.categories.science.label"}}</strong>
                    <p>{{t "help.categories.science.description"}}</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">👥</span>
                    <strong>{{t "help.categories.social.label"}}</strong>
                    <p>{{t "help.categories.social.description"}}</p>
                </div>
            </div>
        </section>

        {{/* Bang Commands */}}
        <section id="bang-commands" class="help-section">
            <h2>{{t "help.bangs.heading"}}</h2>
            <p>{{t "help.bangs.intro_prefix"}} <code>!shortcut terms</code> {{t "help.bangs.intro_or"}} <code>terms !shortcut</code>{{t "help.bangs.intro_suffix"}}</p>

            <h3>{{t "help.bangs.popular_heading"}}</h3>
            <div class="bang-grid">
                <div class="bang-item"><code>!g</code> Google</div>
                <div class="bang-item"><code>!ddg</code> DuckDuckGo</div>
                <div class="bang-item"><code>!b</code> Bing</div>
                <div class="bang-item"><code>!br</code> Brave Search</div>
                <div class="bang-item"><code>!sp</code> Startpage</div>
                <div class="bang-item"><code>!w</code> Wikipedia</div>
                <div class="bang-item"><code>!yt</code> YouTube</div>
                <div class="bang-item"><code>!gh</code> GitHub</div>
                <div class="bang-item"><code>!so</code> Stack Overflow</div>
                <div class="bang-item"><code>!rd</code> Reddit</div>
                <div class="bang-item"><code>!tw</code> Twitter/X</div>
                <div class="bang-item"><code>!az</code> Amazon</div>
                <div class="bang-item"><code>!gm</code> Google Maps</div>
                <div class="bang-item"><code>!osm</code> OpenStreetMap</div>
                <div class="bang-item"><code>!wa</code> Wolfram Alpha</div>
                <div class="bang-item"><code>!mdn</code> MDN Web Docs</div>
                <div class="bang-item"><code>!npm</code> npm</div>
                <div class="bang-item"><code>!pypi</code> PyPI</div>
                <div class="bang-item"><code>!gopkg</code> Go Packages</div>
                <div class="bang-item"><code>!scholar</code> Google Scholar</div>
                <div class="bang-item"><code>!arxiv</code> arXiv</div>
                <div class="bang-item"><code>!archive</code> Internet Archive</div>
                <div class="bang-item"><code>!spot</code> Spotify</div>
            </div>

            <h3>{{t "help.bangs.by_category_heading"}}</h3>
            <table class="operators-table bang-category-table">
                <thead><tr><th>{{t "help.bangs.th_category"}}</th><th>{{t "help.bangs.th_examples"}}</th></tr></thead>
                <tbody>
                    <tr><td>{{t "help.bangs.cat_search"}}</td><td><code>!g</code> <code>!b</code> <code>!ddg</code> <code>!br</code> <code>!sp</code> <code>!q</code> <code>!kagi</code> <code>!perplexity</code></td></tr>
                    <tr><td>{{t "help.bangs.cat_images"}}</td><td><code>!gi</code> <code>!bi</code> <code>!fl</code> <code>!pexels</code> <code>!pixabay</code> <code>!pinterest</code> <code>!tineye</code></td></tr>
                    <tr><td>{{t "help.bangs.cat_video"}}</td><td><code>!yt</code> <code>!v</code> <code>!twitch</code> <code>!tiktok</code> <code>!rumble</code> <code>!pt</code></td></tr>
                    <tr><td>{{t "help.bangs.cat_maps"}}</td><td><code>!gm</code> <code>!osm</code> <code>!waze</code> <code>!yelp</code> <code>!tripadvisor</code></td></tr>
                    <tr><td>{{t "help.bangs.cat_news"}}</td><td><code>!gn</code> <code>!hn</code> <code>!bbc</code> <code>!techcrunch</code> <code>!verge</code> <code>!reuters</code></td></tr>
                    <tr><td>{{t "help.bangs.cat_social"}}</td><td><code>!tw</code> <code>!mast</code> <code>!fb</code> <code>!linkedin</code> <code>!bluesky</code> <code>!lb</code></td></tr>
                    <tr><td>{{t "help.bangs.cat_code_dev"}}</td><td><code>!gh</code> <code>!gl</code> <code>!so</code> <code>!npm</code> <code>!pypi</code> <code>!gopkg</code> <code>!docker</code> <code>!mdn</code></td></tr>
                    <tr><td>{{t "help.bangs.cat_shopping"}}</td><td><code>!az</code> <code>!eb</code></td></tr>
                    <tr><td>{{t "help.bangs.cat_science"}}</td><td><code>!scholar</code> <code>!arxiv</code></td></tr>
                    <tr><td>{{t "help.bangs.cat_reference"}}</td><td><code>!w</code> <code>!wa</code> <code>!britannica</code></td></tr>
                    <tr><td>{{t "help.bangs.cat_files"}}</td><td><code>!archive</code></td></tr>
                </tbody>
            </table>

            <h3>{{t "help.bangs.examples_heading"}}</h3>
            <ul class="example-list">
                <li><code>!g python tutorial</code> — {{t "help.bangs.ex_g_desc"}}</li>
                <li><code>privacy search !ddg</code> — {{t "help.bangs.ex_ddg_desc"}}</li>
                <li><code>!w artificial intelligence</code> — {{t "help.bangs.ex_w_desc"}}</li>
                <li><code>!gh octocat</code> — {{t "help.bangs.ex_gh_desc"}}</li>
                <li><code>!npm express</code> — {{t "help.bangs.ex_npm_desc"}}</li>
            </ul>
            <p><a href="/api/v1/bangs">{{t "help.bangs.full_list_link"}}</a></p>
        </section>

        {{/* Direct Answers */}}
        <section id="direct-answers" class="help-section">
            <h2>{{t "help.direct.heading"}}</h2>
            <p><strong>{{t "help.direct.intro_da_label"}}</strong> {{t "help.direct.intro_da_text_prefix"}} <code>type:term</code> {{t "help.direct.intro_da_text_suffix"}} <strong>{{t "help.direct.intro_ia_label"}}</strong> {{t "help.direct.intro_ia_text"}}</p>

            <h3>{{t "help.direct.full_page_heading"}} (<code>type:term</code>)</h3>

            <h3>{{t "help.direct.network.heading"}}</h3>
            <div class="operator-grid">
                <div class="operator-item"><code>dns:example.com</code><span>{{t "help.direct.network.dns"}}</span></div>
                <div class="operator-item"><code>whois:example.com</code><span>{{t "help.direct.network.whois"}}</span></div>
                <div class="operator-item"><code>cert:example.com</code><span>{{t "help.direct.network.cert"}}</span></div>
                <div class="operator-item"><code>headers:example.com</code><span>{{t "help.direct.network.headers"}}</span></div>
                <div class="operator-item"><code>asn:AS15169</code><span>{{t "help.direct.network.asn"}}</span></div>
                <div class="operator-item"><code>subnet:192.168.1.0/24</code><span>{{t "help.direct.network.subnet"}}</span></div>
                <div class="operator-item"><code>resolve:example.com</code><span>{{t "help.direct.network.resolve"}}</span></div>
                <div class="operator-item"><code>robots:example.com</code><span>{{t "help.direct.network.robots"}}</span></div>
                <div class="operator-item"><code>sitemap:example.com</code><span>{{t "help.direct.network.sitemap"}}</span></div>
                <div class="operator-item"><code>tech:example.com</code><span>{{t "help.direct.network.tech"}}</span></div>
                <div class="operator-item"><code>feed:example.com</code><span>{{t "help.direct.network.feed"}}</span></div>
                <div class="operator-item"><code>expand:short.url/x</code><span>{{t "help.direct.network.expand"}}</span></div>
                <div class="operator-item"><code>safe:example.com</code><span>{{t "help.direct.network.safe"}}</span></div>
            </div>

            <h3>{{t "help.direct.encoding.heading"}}</h3>
            <div class="operator-grid">
                <div class="operator-item"><code>qr:https://example.com</code><span>{{t "help.direct.encoding.qr"}}</span></div>
                <div class="operator-item"><code>jwt:token</code><span>{{t "help.direct.encoding.jwt"}}</span></div>
                <div class="operator-item"><code>html:&lt;b&gt;text&lt;/b&gt;</code><span>{{t "help.direct.encoding.html"}}</span></div>
                <div class="operator-item"><code>escape:hello &amp; world</code><span>{{t "help.direct.encoding.escape"}}</span></div>
                <div class="operator-item"><code>ascii:hello</code><span>{{t "help.direct.encoding.ascii"}}</span></div>
                <div class="operator-item"><code>unicode:U+1F600</code><span>{{t "help.direct.encoding.unicode"}}</span></div>
                <div class="operator-item"><code>emoji:smile</code><span>{{t "help.direct.encoding.emoji"}}</span></div>
            </div>

            <h3>{{t "help.direct.dev.heading"}}</h3>
            <div class="operator-grid">
                <div class="operator-item"><code>json:format {"key":"val"}</code><span>{{t "help.direct.dev.json"}}</span></div>
                <div class="operator-item"><code>yaml:from-json {"key":"val"}</code><span>{{t "help.direct.dev.yaml"}}</span></div>
                <div class="operator-item"><code>regex:[a-z]+</code><span>{{t "help.direct.dev.regex"}}</span></div>
                <div class="operator-item"><code>beautify:code</code><span>{{t "help.direct.dev.beautify"}}</span></div>
                <div class="operator-item"><code>cron:* * * * *</code><span>{{t "help.direct.dev.cron"}}</span></div>
                <div class="operator-item"><code>chmod:755</code><span>{{t "help.direct.dev.chmod"}}</span></div>
                <div class="operator-item"><code>timestamp:1700000000</code><span>{{t "help.direct.dev.timestamp"}}</span></div>
                <div class="operator-item"><code>slug:Hello World</code><span>{{t "help.direct.dev.slug"}}</span></div>
                <div class="operator-item"><code>case:hello world</code><span>{{t "help.direct.dev.case"}}</span></div>
            </div>

            <h3>{{t "help.direct.reference.heading"}}</h3>
            <div class="operator-grid">
                <div class="operator-item"><code>tldr:git</code><span>{{t "help.direct.reference.tldr"}}</span></div>
                <div class="operator-item"><code>man:grep</code><span>{{t "help.direct.reference.man"}}</span></div>
                <div class="operator-item"><code>cheat:git</code><span>{{t "help.direct.reference.cheat"}}</span></div>
                <div class="operator-item"><code>rfc:2616</code><span>{{t "help.direct.reference.rfc"}}</span></div>
                <div class="operator-item"><code>cve:CVE-2024-1234</code><span>{{t "help.direct.reference.cve"}}</span></div>
                <div class="operator-item"><code>pkg:express</code><span>{{t "help.direct.reference.pkg"}}</span></div>
                <div class="operator-item"><code>http:404</code><span>{{t "help.direct.reference.http"}}</span></div>
                <div class="operator-item"><code>port:443</code><span>{{t "help.direct.reference.port"}}</span></div>
            </div>

            <h3>{{t "help.direct.content.heading"}}</h3>
            <div class="operator-grid">
                <div class="operator-item"><code>wiki:python</code><span>{{t "help.direct.content.wiki"}}</span></div>
                <div class="operator-item"><code>dict:ephemeral</code><span>{{t "help.direct.content.dict"}}</span></div>
                <div class="operator-item"><code>thesaurus:happy</code><span>{{t "help.direct.content.thesaurus"}}</span></div>
                <div class="operator-item"><code>slang:yolo</code><span>{{t "help.direct.content.slang"}}</span></div>
                <div class="operator-item"><code>country:DE</code><span>{{t "help.direct.content.country"}}</span></div>
                <div class="operator-item"><code>license:MIT</code><span>{{t "help.direct.content.license"}}</span></div>
            </div>

            <h3>{{t "help.direct.text.heading"}}</h3>
            <div class="operator-grid">
                <div class="operator-item"><code>lorem:3</code><span>{{t "help.direct.text.lorem"}}</span></div>
                <div class="operator-item"><code>word:hello world</code><span>{{t "help.direct.text.word"}}</span></div>
                <div class="operator-item"><code>diff:text1|text2</code><span>{{t "help.direct.text.diff"}}</span></div>
                <div class="operator-item"><code>useragent:my</code><span>{{t "help.direct.text.useragent"}}</span></div>
                <div class="operator-item"><code>mime:application/json</code><span>{{t "help.direct.text.mime"}}</span></div>
            </div>

            <h3>{{t "help.direct.directories.heading"}}</h3>
            <div class="operator-grid">
                <div class="operator-item"><code>directory:linux iso</code><span>{{t "help.direct.directories.linux"}}</span></div>
                <div class="operator-item"><code>directory:pdf book</code><span>{{t "help.direct.directories.pdf"}}</span></div>
                <div class="operator-item"><code>directory:mp3 album</code><span>{{t "help.direct.directories.mp3"}}</span></div>
            </div>

            <h3>{{t "help.direct.cache.heading"}}</h3>
            <div class="operator-grid">
                <div class="operator-item"><code>cache:example.com</code><span>{{t "help.direct.cache.cached"}}</span></div>
                <div class="operator-item"><code>rotl:34</code><span>{{t "help.direct.cache.rotl"}}</span></div>
            </div>

            <h3>{{t "help.direct.instant.heading"}}</h3>
            <div class="operator-grid">
                <div class="operator-item"><code>2 + 2</code><span>{{t "help.direct.instant.calc"}}</span></div>
                <div class="operator-item"><code>sqrt(144)</code><span>{{t "help.direct.instant.math"}}</span></div>
                <div class="operator-item"><code>convert 10 km to miles</code><span>{{t "help.direct.instant.convert"}}</span></div>
                <div class="operator-item"><code>time in tokyo</code><span>{{t "help.direct.instant.time"}}</span></div>
                <div class="operator-item"><code>what is my ip</code><span>{{t "help.direct.instant.ip"}}</span></div>
                <div class="operator-item"><code>#ff5733</code><span>{{t "help.direct.instant.color"}}</span></div>
            </div>
        </section>

        {{/* Search Operators */}}
        <section id="search-operators" class="help-section">
            <h2>{{t "help.operators.heading"}}</h2>
            <p>{{t "help.operators.intro"}}</p>
            <table class="operators-table search-operators-table">
                <thead>
                    <tr><th>{{t "help.operators.th_operator"}}</th><th>{{t "help.operators.th_example"}}</th><th>{{t "help.operators.th_description"}}</th></tr>
                </thead>
                <tbody>
                    <tr><td><code>"..."</code></td><td><code>"exact phrase"</code></td><td>{{t "help.operators.exact_phrase"}}</td></tr>
                    <tr><td><code>-word</code></td><td><code>apple -fruit</code></td><td>{{t "help.operators.exclude_word"}}</td></tr>
                    <tr><td><code>*</code></td><td><code>best * for python</code></td><td>{{t "help.operators.wildcard"}}</td></tr>
                    <tr><td><code>OR</code></td><td><code>cat OR dog</code></td><td>{{t "help.operators.or"}}</td></tr>
                    <tr><td><code>AND</code></td><td><code>privacy AND security</code></td><td>{{t "help.operators.and"}}</td></tr>
                    <tr><td><code>site:</code></td><td><code>site:example.com query</code></td><td>{{t "help.operators.site"}}</td></tr>
                    <tr><td><code>-site:</code></td><td><code>-site:spam.com query</code></td><td>{{t "help.operators.site_exclude"}}</td></tr>
                    <tr><td><code>filetype:</code></td><td><code>filetype:pdf report</code></td><td>{{t "help.operators.filetype"}}</td></tr>
                    <tr><td><code>intitle:</code></td><td><code>intitle:guide</code></td><td>{{t "help.operators.intitle"}}</td></tr>
                    <tr><td><code>inurl:</code></td><td><code>inurl:blog</code></td><td>{{t "help.operators.inurl"}}</td></tr>
                    <tr><td><code>intext:</code></td><td><code>intext:privacy policy</code></td><td>{{t "help.operators.intext"}}</td></tr>
                    <tr><td><code>define:</code></td><td><code>define:ephemeral</code></td><td>{{t "help.operators.define"}}</td></tr>
                    <tr><td><code>before:</code></td><td><code>before:2023-01-01 python</code></td><td>{{t "help.operators.before"}}</td></tr>
                    <tr><td><code>after:</code></td><td><code>after:2024-01-01 python</code></td><td>{{t "help.operators.after"}}</td></tr>
                    <tr><td><code>lang:</code></td><td><code>lang:en linux</code></td><td>{{t "help.operators.lang"}}</td></tr>
                    <tr><td><code>related:</code></td><td><code>related:github.com</code></td><td>{{t "help.operators.related"}}</td></tr>
                    <tr><td><code>cache:</code></td><td><code>cache:example.com</code></td><td>{{t "help.operators.cache"}}</td></tr>
                    <tr><td><code>info:</code></td><td><code>info:example.com</code></td><td>{{t "help.operators.info"}}</td></tr>
                    <tr><td><code>define:</code></td><td><code>define:ephemeral</code></td><td>{{t "help.operators.define_alt"}}</td></tr>
                    <tr><td><code>weather:</code></td><td><code>weather:tokyo</code></td><td>{{t "help.operators.weather"}}</td></tr>
                    <tr><td><code>stocks:</code></td><td><code>stocks:AAPL</code></td><td>{{t "help.operators.stocks"}}</td></tr>
                    <tr><td><code>map:</code></td><td><code>map:berlin</code></td><td>{{t "help.operators.map"}}</td></tr>
                    <tr><td><code>movie:</code></td><td><code>movie:arrival</code></td><td>{{t "help.operators.movie"}}</td></tr>
                    <tr><td><code>source:</code></td><td><code>source:reuters ai</code></td><td>{{t "help.operators.source"}}</td></tr>
                </tbody>
            </table>
        </section>

        {{/* Keyboard Shortcuts */}}
        <section id="keyboard-shortcuts" class="help-section">
            <h2>{{t "help.shortcuts.heading"}}</h2>
            <p>{{t "help.shortcuts.intro"}}</p>
            <table class="shortcuts-table shortcuts-help-table">
                <thead>
                    <tr><th>{{t "help.shortcuts.th_shortcut"}}</th><th>{{t "help.shortcuts.th_action"}}</th></tr>
                </thead>
                <tbody>
                    <tr><td><kbd>/</kbd> or <kbd>s</kbd></td><td>{{t "help.shortcuts.focus_search"}}</td></tr>
                    <tr><td><kbd>Escape</kbd></td><td>{{t "help.shortcuts.clear_close"}}</td></tr>
                    <tr><td><kbd>t</kbd></td><td>{{t "help.shortcuts.cycle_theme"}}</td></tr>
                    <tr><td><kbd>?</kbd></td><td>{{t "help.shortcuts.show_help"}}</td></tr>
                    <tr><td><kbd>j</kbd> / <kbd>k</kbd></td><td>{{t "help.shortcuts.navigate_results"}}</td></tr>
                    <tr><td><kbd>Enter</kbd></td><td>{{t "help.shortcuts.open_selected"}}</td></tr>
                    <tr><td><kbd>o</kbd> / <kbd>O</kbd></td><td>{{t "help.shortcuts.open_tab_or_new"}}</td></tr>
                    <tr><td><kbd>h</kbd> / <kbd>l</kbd></td><td>{{t "help.shortcuts.prev_next_page"}}</td></tr>
                    <tr><td><kbd>g</kbd><kbd>g</kbd> / <kbd>G</kbd></td><td>{{t "help.shortcuts.first_last"}}</td></tr>
                    <tr><td><kbd>1</kbd>–<kbd>9</kbd></td><td>{{t "help.shortcuts.open_n"}}</td></tr>
                </tbody>
            </table>
        </section>

        {{/* API Documentation */}}
        <section id="api-docs" class="help-section api-docs">
            <h2>{{t "help.api.heading"}}</h2>
            <p>{{t "help.api.intro"}}</p>
            <div class="api-links">
                <a href="/openapi" class="api-link-card">
                    <h3>{{t "help.api.openapi_heading"}}</h3>
                    <p>{{t "help.api.openapi_desc"}}</p>
                </a>
                <a href="/graphql" class="api-link-card">
                    <h3>{{t "help.api.graphql_heading"}}</h3>
                    <p>{{t "help.api.graphql_desc"}}</p>
                </a>
            </div>

            <h3>{{t "help.api.endpoints_heading"}}</h3>
            <table class="operators-table api-endpoints-table">
                <thead>
                    <tr><th>{{t "help.api.th_method"}}</th><th>{{t "help.api.th_endpoint"}}</th><th>{{t "help.api.th_description"}}</th></tr>
                </thead>
                <tbody>
                    <tr><td><code>GET</code></td><td><code>/api/v1/search</code></td><td>{{t "help.api.ep_search"}}</td></tr>
                    <tr><td><code>GET</code></td><td><code>/api/v1/search/related</code></td><td>{{t "help.api.ep_related"}}</td></tr>
                    <tr><td><code>GET</code></td><td><code>/api/v1/autocomplete</code></td><td>{{t "help.api.ep_autocomplete"}}</td></tr>
                    <tr><td><code>GET</code></td><td><code>/api/v1/instant</code></td><td>{{t "help.api.ep_instant"}}</td></tr>
                    <tr><td><code>GET</code></td><td><code>/api/v1/direct/{type}/{term}</code></td><td>{{t "help.api.ep_direct_prefix"}} <code>type:term</code> {{t "help.api.ep_direct_suffix"}}</td></tr>
                    <tr><td><code>GET</code></td><td><code>/api/v1/engines</code></td><td>{{t "help.api.ep_engines"}}</td></tr>
                    <tr><td><code>GET</code></td><td><code>/api/v1/categories</code></td><td>{{t "help.api.ep_categories"}}</td></tr>
                    <tr><td><code>GET</code></td><td><code>/api/v1/bangs</code></td><td>{{t "help.api.ep_bangs"}}</td></tr>
                    <tr><td><code>GET</code></td><td><code>/api/v1/server/help</code></td><td>{{t "help.api.ep_help_json"}}</td></tr>
                    <tr><td><code>GET</code></td><td><code>/openapi</code> / <code>/openapi.json</code></td><td>{{t "help.api.ep_openapi"}}</td></tr>
                    <tr><td><code>GET</code> / <code>POST</code></td><td><code>/graphql</code></td><td>{{t "help.api.ep_graphql"}}</td></tr>
                    {{if .Config.Search.OpenSearch.Enabled}}
                    <tr><td><code>GET</code></td><td><code>/opensearch.xml</code></td><td>{{t "help.api.ep_opensearch"}}</td></tr>
                    {{end}}
                </tbody>
            </table>

            <h3>{{t "help.api.example_search"}}</h3>
            <pre class="code-block"><code># Search for "golang tutorial"
curl "{{.ServerURL}}/api/v1/search?q=golang+tutorial&category=general&limit=20"

# Image search with strict safe search
curl "{{.ServerURL}}/api/v1/search?q=nature&category=images&safe_search=2"

# Get related searches
curl "{{.ServerURL}}/api/v1/search/related?q=golang+tutorial"</code></pre>

            <h3>{{t "help.api.example_instant"}}</h3>
            <pre class="code-block"><code># Calculator
curl "{{.ServerURL}}/api/v1/instant?q=sqrt(144)"

# Unit conversion
curl "{{.ServerURL}}/api/v1/instant?q=convert+10+km+to+miles"

# IP lookup
curl "{{.ServerURL}}/api/v1/instant?q=what+is+my+ip"</code></pre>

            <h3>{{t "help.api.example_direct"}}</h3>
            <pre class="code-block"><code># HTTP status explanation
curl "{{.ServerURL}}/api/v1/direct/http/404"

# Rules of the Internet
curl "{{.ServerURL}}/api/v1/direct/rules/34"</code></pre>
        </section>

        {{/* Privacy Features */}}
        <section id="privacy" class="help-section">
            <h2>{{t "help.privacy.heading"}}</h2>
            <ul class="privacy-list">
                <li><strong>{{t "help.privacy.no_tracking_label"}}</strong> {{t "help.privacy.no_tracking_text"}}</li>
                <li><strong>{{t "help.privacy.no_history_label"}}</strong> {{t "help.privacy.no_history_text"}}</li>
                <li><strong>{{t "help.privacy.sanitized_links_label"}}</strong> {{t "help.privacy.sanitized_links_text"}}</li>
                <li><strong>{{t "help.privacy.tor_support_label"}}</strong> {{t "help.privacy.tor_support_prefix"}}{{if .Config.Server.Tor.Enabled}} (<a href="#tor-access">{{t "help.privacy.tor_support_see_below"}}</a>){{end}}</li>
                <li><strong>{{t "help.privacy.minimal_cookies_label"}}</strong> {{t "help.privacy.minimal_cookies_text"}}</li>
                <li><strong>{{t "help.privacy.no_js_label"}}</strong> {{t "help.privacy.no_js_text"}}</li>
                <li><strong>{{t "help.privacy.open_source_label"}}</strong> {{t "help.privacy.open_source_text"}}</li>
            </ul>
        </section>

        {{/* Tor Access - only shown if Tor is enabled */}}
        {{if .Config.Server.Tor.Enabled}}
        <section id="tor-access" class="help-section tor-access">
            <h2>{{t "help.tor.heading"}}</h2>
            <p>{{t "help.tor.intro"}}</p>

            {{if .TorAddress}}
            <h3>{{t "help.tor.onion_heading"}}</h3>
            <div class="onion-address-box">
                <code id="onion-addr" class="onion-address">{{.TorAddress}}</code>
                <button class="btn-copy" data-copy-target="onion-addr" aria-label="{{t "help.tor.copy_aria"}}">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                    {{t "help.tor.copy_label"}}
                </button>
            </div>
            {{else}}
            <p class="tor-note">{{t "help.tor.pending_note"}}</p>
            {{end}}

            <h3>{{t "help.tor.how_to_heading"}}</h3>
            <ol>
                <li>{{t "help.tor.step_download"}} <a href="https://www.torproject.org/download/" target="_blank" rel="noopener">Tor Browser</a></li>
                <li>{{t "help.tor.step_open"}}</li>
                <li>{{t "help.tor.step_paste"}}</li>
            </ol>

            <p class="tor-note">{{t "help.tor.footer_note"}}</p>
        </section>
        {{end}}

        {{/* FAQ */}}
        <section id="faq" class="help-section">
            <h2>{{t "help.faq.heading"}}</h2>
            <div class="faq-list">
                <details>
                    <summary>{{t "help.faq.q_results_diff"}}</summary>
                    <p>{{t "help.faq.a_results_diff"}}</p>
                </details>
                <details>
                    <summary>{{t "help.faq.q_tor_access_summary"}}</summary>
                    <p>{{t "help.faq.a_tor_access_prefix"}} <a href="https://www.torproject.org/download/" target="_blank" rel="noopener">Tor Browser</a> {{t "help.faq.a_tor_access_suffix"}}{{if .Config.Server.Tor.Enabled}} <a href="#tor-access">{{t "help.faq.a_tor_access_see_section"}}</a>{{end}}</p>
                </details>
                <details>
                    <summary>{{t "help.faq.q_self_host"}}</summary>
                    <p>{{t "help.faq.a_self_host_prefix"}}{{if .Config.Server.Branding.SourceCodeURL}} <a href="{{.Config.Server.Branding.SourceCodeURL}}" target="_blank" rel="noopener">{{t "help.faq.a_self_host_repo"}}</a>{{end}}</p>
                </details>
                <details>
                    <summary>{{t "help.faq.q_engines"}}</summary>
                    <p>{{t "help.faq.a_engines"}}</p>
                </details>
                <details>
                    <summary>{{t "help.faq.q_instant"}}</summary>
                    <p>{{t "help.faq.a_instant"}}</p>
                </details>
            </div>
        </section>

        {{/* Need Help */}}
        <section class="help-section">
            <h2>{{t "help.need_more.heading"}}</h2>
            <p>{{t "help.need_more.text_prefix"}} <a href="/server/contact">{{t "help.need_more.link"}}</a>{{t "help.need_more.text_suffix"}}</p>
        </section>
    </div>
    {{end}}
</div>
{{end}}
