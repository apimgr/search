                </div>
                <div class="operator-item">
                    <code>escape:hello &amp; world</code>
                    <span>Escape special characters</span>
                </div>
                <div class="operator-item">
                    <code>ascii:hello</code>
                    <span>ASCII art text</span>
                </div>
                <div class="operator-item">
