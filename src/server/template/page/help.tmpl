{{define "content"}}
<div class="static-page help-page">
    <header class="help-header">
        <h1>Help & Documentation</h1>
        <p class="subtitle">Learn how to get the most out of {{.Config.Server.Branding.Title}}</p>
    </header>

    {{if .Config.Server.Pages.Help.Content}}
    <div class="page-content markdown">
        {{.Config.Server.Pages.Help.Content | safe}}
    </div>
    {{else}}
    <div class="page-content">
        {{/* Table of Contents */}}
        <nav class="help-toc">
            <h2>Contents</h2>
            <ul>
                <li><a href="#getting-started">Getting Started</a></li>
                <li><a href="#search-categories">Search Categories</a></li>
                <li><a href="#bang-commands">Bang Commands</a></li>
                <li><a href="#direct-answers">Direct Answers</a></li>
                <li><a href="#search-operators">Search Operators</a></li>
                <li><a href="#keyboard-shortcuts">Keyboard Shortcuts</a></li>
                <li><a href="#api-docs">API Documentation</a></li>
                <li><a href="#privacy">Privacy Features</a></li>
                {{if .Config.Server.Tor.Enabled}}<li><a href="#tor-access">Tor Access</a></li>{{end}}
                <li><a href="#faq">FAQ</a></li>
            </ul>
        </nav>

        {{/* Getting Started */}}
        <section id="getting-started" class="help-section">
            <h2>Getting Started</h2>
            <p>{{.Config.Server.Branding.Title}} is a privacy-respecting metasearch engine. Simply type your query in the search box and press <kbd>Enter</kbd> or click the search button.</p>
            <p>Unlike traditional search engines, we don't track you, store your search history, or create a profile about you.</p>
        </section>

        {{/* Search Categories */}}
        <section id="search-categories" class="help-section">
            <h2>Search Categories</h2>
            <p>Use the category tabs to filter your results:</p>
            <div class="category-grid">
                <div class="category-item">
                    <span class="category-icon">🌐</span>
                    <strong>General</strong>
                    <p>Web pages and articles</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">🖼️</span>
                    <strong>Images</strong>
                    <p>Photos and graphics</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">🎬</span>
                    <strong>Videos</strong>
                    <p>Video content</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">📰</span>
                    <strong>News</strong>
                    <p>Recent news articles</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">🗺️</span>
                    <strong>Maps</strong>
                    <p>Locations and directions</p>
                </div>
                <div class="category-item">
                    <span class="category-icon">📚</span>
                    <strong>Science</strong>
                    <p>Academic papers (arXiv, PubMed)</p>
                </div>
            </div>
        </section>

        {{/* Bang Commands */}}
        <section id="bang-commands" class="help-section">
            <h2>Bang Commands</h2>
            <p>Bang commands let you search other sites directly. Start your query with a bang (<code>!</code>) followed by the site shortcut. 180+ bangs are available.</p>

            <h3>Popular Bangs</h3>
            <div class="bang-grid">
                <div class="bang-item"><code>!g</code> Google</div>
                <div class="bang-item"><code>!ddg</code> DuckDuckGo</div>
                <div class="bang-item"><code>!b</code> Bing</div>
                <div class="bang-item"><code>!w</code> Wikipedia</div>
                <div class="bang-item"><code>!yt</code> YouTube</div>
                <div class="bang-item"><code>!gh</code> GitHub</div>
                <div class="bang-item"><code>!so</code> Stack Overflow</div>
                <div class="bang-item"><code>!r</code> Reddit</div>
                <div class="bang-item"><code>!tw</code> Twitter/X</div>
                <div class="bang-item"><code>!amz</code> Amazon</div>
                <div class="bang-item"><code>!gm</code> Google Maps</div>
                <div class="bang-item"><code>!osm</code> OpenStreetMap</div>
                <div class="bang-item"><code>!wa</code> Wolfram Alpha</div>
                <div class="bang-item"><code>!mdn</code> MDN Web Docs</div>
                <div class="bang-item"><code>!npm</code> NPM</div>
                <div class="bang-item"><code>!pypi</code> PyPI</div>
                <div class="bang-item"><code>!crates</code> Crates.io</div>
                <div class="bang-item"><code>!scholar</code> Google Scholar</div>
                <div class="bang-item"><code>!arxiv</code> arXiv</div>
                <div class="bang-item"><code>!imdb</code> IMDb</div>
                <div class="bang-item"><code>!steam</code> Steam</div>
                <div class="bang-item"><code>!spot</code> Spotify</div>
            </div>

            <h3>By Category</h3>
            <table class="operators-table">
                <thead><tr><th>Category</th><th>Examples</th></tr></thead>
                <tbody>
                    <tr><td>Search</td><td><code>!g</code> <code>!b</code> <code>!ddg</code> <code>!br</code> <code>!sp</code> <code>!q</code> <code>!kagi</code> <code>!perplexity</code></td></tr>
                    <tr><td>Images</td><td><code>!gi</code> <code>!bi</code> <code>!fl</code> <code>!pexels</code> <code>!pixabay</code> <code>!pinterest</code> <code>!tineye</code></td></tr>
                    <tr><td>Video</td><td><code>!yt</code> <code>!v</code> <code>!twitch</code> <code>!tiktok</code> <code>!rumble</code> <code>!pt</code></td></tr>
                    <tr><td>Maps</td><td><code>!gm</code> <code>!osm</code> <code>!waze</code> <code>!yelp</code> <code>!tripadvisor</code></td></tr>
                    <tr><td>News</td><td><code>!gn</code> <code>!hn</code> <code>!bbc</code> <code>!techcrunch</code> <code>!verge</code> <code>!reuters</code></td></tr>
                    <tr><td>Social</td><td><code>!tw</code> <code>!mast</code> <code>!fb</code> <code>!linkedin</code> <code>!bluesky</code> <code>!lb</code></td></tr>
                    <tr><td>Code &amp; Dev</td><td><code>!gh</code> <code>!gl</code> <code>!so</code> <code>!npm</code> <code>!pypi</code> <code>!crates</code> <code>!docker</code> <code>!mdn</code></td></tr>
                    <tr><td>Shopping</td><td><code>!amz</code> <code>!eb</code> <code>!etsy</code> <code>!walmart</code> <code>!camelcamelcamel</code></td></tr>
                    <tr><td>Science</td><td><code>!scholar</code> <code>!arxiv</code> <code>!pubmed</code> <code>!doi</code></td></tr>
                    <tr><td>Reference</td><td><code>!w</code> <code>!wa</code> <code>!mw</code> <code>!ud</code> <code>!britannica</code></td></tr>
                    <tr><td>Privacy</td><td><code>!wbm</code> <code>!virustotal</code> <code>!shodan</code> <code>!urlscan</code></td></tr>
                    <tr><td>Entertainment</td><td><code>!imdb</code> <code>!rt</code> <code>!steam</code> <code>!spot</code> <code>!letterboxd</code></td></tr>
                </tbody>
            </table>

            <h3>Examples</h3>
            <ul class="example-list">
                <li><code>!g python tutorial</code> — Search Google for "python tutorial"</li>
                <li><code>!w artificial intelligence</code> — Go to Wikipedia article</li>
                <li><code>!gh octocat</code> — Search GitHub</li>
                <li><code>!npm express</code> — Look up npm package</li>
            </ul>
            <p><a href="/api/v1/bangs">View full bang list (JSON)</a></p>
        </section>

        {{/* Direct Answers */}}
