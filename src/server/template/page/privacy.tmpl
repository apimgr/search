{{define "content"}}
<div class="static-page privacy-page">
    <header class="page-header">
        <h1>{{t "footer.privacy_policy"}}</h1>
    </header>

    {{if .Config.Server.Pages.Privacy.Content}}
    <div class="page-content markdown">
        {{.Config.Server.Pages.Privacy.Content | safe}}
    </div>
    {{else}}
    <div class="page-content">
        <section class="privacy-section">
            <h2>{{t "privacy.data_collection_heading"}}</h2>
            <p>{{t "privacy.data_collection_description" (default (t "home.brand_fallback") .Config.Server.Branding.Title)}}</p>
            <ul>
                <li><strong>{{t "privacy.search_queries_label"}}:</strong> {{t "privacy.search_queries_description"}}</li>
                <li><strong>{{t "privacy.ip_addresses_label"}}:</strong> {{t "privacy.ip_addresses_description"}}</li>
                <li><strong>{{t "privacy.cookies_label"}}:</strong> {{t "privacy.cookies_description"}}</li>
            </ul>
        </section>

        <section class="privacy-section">
            <h2>{{t "privacy.data_usage_heading"}}</h2>
            <p>{{t "privacy.data_usage_description"}}</p>
            <ul>
                <li>{{t "privacy.data_usage_item_forward"}}</li>
                <li>{{t "privacy.data_usage_item_aggregate"}}</li>
                <li>{{t "privacy.data_usage_item_preferences"}}</li>
            </ul>
        </section>

        <section class="privacy-section">
            <h2>{{t "privacy.data_retention_heading"}}</h2>
            <p>{{t "privacy.data_retention_description"}}</p>
        </section>

        <section class="privacy-section">
            <h2>{{t "privacy.third_parties_heading"}}</h2>
            <p>{{t "privacy.third_parties_description"}}</p>
            <p>{{t "privacy.third_parties_followup"}}</p>
        </section>

        <section class="privacy-section">
            <h2>{{t "privacy.cookies_heading"}}</h2>
            <p>{{t "privacy.cookies_intro"}}</p>
            <ul>
                <li><strong>{{t "privacy.session_cookie_label"}}:</strong> {{t "privacy.session_cookie_description"}}</li>
                <li><strong>{{t "privacy.preference_cookie_label"}}:</strong> {{t "privacy.preference_cookie_description"}}</li>
            </ul>
            <p>{{t "privacy.cookies_followup"}}</p>
        </section>

        <section class="privacy-section">
            <h2>{{t "privacy.your_rights_heading"}}</h2>
            <p>{{t "privacy.your_rights_description"}}</p>
        </section>

        <section class="privacy-section">
            <h2>{{t "contact.page_title"}}</h2>
            <p>{{t "privacy.contact_prefix"}} <a href="/server/contact">{{t "contact.title"}}</a>{{t "privacy.contact_suffix"}}</p>
        </section>
    </div>
    {{end}}
</div>
{{end}}
