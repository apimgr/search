{{define "content"}}
<section class="page-section alert-page">
    <div class="page-header">
        <h1>{{t "alerts.created_title"}}</h1>
    </div>
    {{if .VerificationSent}}
    <p>{{t "alerts.check_email_confirm"}}</p>
    {{else}}
    <p>{{t "alerts.alert_active"}}</p>
    {{end}}
    {{if .ManageURL}}
    <p><strong>{{t "alerts.manage_link_label"}}</strong> <a href="{{.ManageURL}}">{{.ManageURL}}</a></p>
    {{end}}
    {{if .RSSURL}}
    <p><strong>{{t "alerts.private_rss_feed_label"}}</strong> <a href="{{.RSSURL}}">{{.RSSURL}}</a></p>
    {{end}}
</section>
{{end}}
