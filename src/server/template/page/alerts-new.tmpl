{{define "content"}}
<section class="page-section alert-page">
    <div class="page-header">
        <h1>{{t "alerts.create_title"}}</h1>
        <p>{{t "alerts.create_subtitle"}}</p>
    </div>
    {{if .Success}}
    <div class="search-info"><span>{{.Success}}</span></div>
    {{end}}
    {{if .Error}}
    <div class="search-error"><p>{{.Error}}</p></div>
    {{end}}
    <form method="POST" action="/alerts" class="alert-form">
        <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
        <div class="form-group">
            <label for="query">{{t "alerts.search_query_label"}}</label>
            <input id="query" name="query" type="text" value="{{.Query}}" required>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label for="category">{{t "search.category"}}</label>
                <select id="category" name="category">
                    <option value="general" {{if eq .Category "general"}}selected{{end}}>{{t "preferences.default_category_general"}}</option>
                    <option value="images" {{if eq .Category "images"}}selected{{end}}>{{t "search.categories.images"}}</option>
                    <option value="videos" {{if eq .Category "videos"}}selected{{end}}>{{t "search.categories.videos"}}</option>
                    <option value="news" {{if eq .Category "news"}}selected{{end}}>{{t "search.categories.news"}}</option>
                    <option value="maps" {{if eq .Category "maps"}}selected{{end}}>{{t "search.categories.maps"}}</option>
                    <option value="files" {{if eq .Category "files"}}selected{{end}}>{{t "search.categories.files"}}</option>
                    <option value="music" {{if eq .Category "music"}}selected{{end}}>{{t "preferences.default_category_music"}}</option>
                    <option value="science" {{if eq .Category "science"}}selected{{end}}>{{t "search.categories.science"}}</option>
                    <option value="it" {{if eq .Category "it"}}selected{{end}}>{{t "search.categories.it"}}</option>
                    <option value="social" {{if eq .Category "social"}}selected{{end}}>{{t "search.categories.social"}}</option>
                </select>
            </div>
            <div class="form-group">
                <label for="language">{{t "search.language"}}</label>
                <input id="language" name="language" type="text" value="{{.Language}}" placeholder="en" autocapitalize="off" spellcheck="false">
            </div>
            <div class="form-group">
                <label for="region">{{t "search.region"}}</label>
                <input id="region" name="region" type="text" value="{{.Region}}" placeholder="us" autocapitalize="off" spellcheck="false">
            </div>
            <div class="form-group">
                <label for="safe_search">{{t "search.safe_search"}}</label>
                <select id="safe_search" name="safe_search">
                    <option value="0" {{if eq .SafeSearch 0}}selected{{end}}>{{t "search.safe_search_off"}}</option>
                    <option value="1" {{if eq .SafeSearch 1}}selected{{end}}>{{t "search.safe_search_moderate"}}</option>
                    <option value="2" {{if eq .SafeSearch 2}}selected{{end}}>{{t "search.safe_search_strict"}}</option>
                </select>
            </div>
            <div class="form-group">
                <label for="frequency">{{t "alerts.frequency_label"}}</label>
                <select id="frequency" name="frequency">
                    <option value="immediate" {{if eq .Frequency "immediate"}}selected{{end}}>{{t "admin.settings_page.frequency_immediate"}}</option>
                    <option value="daily" {{if eq .Frequency "daily"}}selected{{end}}>{{t "admin.settings_page.frequency_daily"}}</option>
                    <option value="weekly" {{if eq .Frequency "weekly"}}selected{{end}}>{{t "admin.settings_page.frequency_weekly"}}</option>
                </select>
            </div>
        </div>
        <fieldset class="alert-channels">
            <legend>{{t "alerts.engine_filters_legend"}}</legend>
            <p class="form-help">{{t "alerts.engine_filters_help"}}</p>
            <div class="alert-engine-grid">
                {{range .AvailableEngines}}
                <label><input type="checkbox" name="engines" value="{{.Name}}" {{if .Selected}}checked{{end}}> {{.DisplayName}}</label>
                {{end}}
            </div>
        </fieldset>
        <div class="form-group">
            <label for="email">{{t "alerts.contact_email_label"}}</label>
            <input id="email" name="email" type="email" required>
            {{if not .EmailEnabled}}
            <p class="form-help">{{t "alerts.email_unavailable_help"}}</p>
            {{end}}
        </div>
        <fieldset class="alert-channels">
            <legend>{{t "alerts.delivery_channels_legend"}}</legend>
            {{if .EmailEnabled}}
            <label><input type="checkbox" name="deliver_email"> {{t "alerts.delivery_email_digest"}}</label>
            {{end}}
            <label><input type="checkbox" name="deliver_rss" {{if .DefaultRSS}}checked{{end}}> {{t "alerts.delivery_private_rss"}}</label>
            <label><input type="checkbox" name="deliver_webhook" {{if .DefaultWebhook}}checked{{end}}> {{t "alerts.delivery_webhook"}}</label>
        </fieldset>
        <div class="form-group">
            <label for="webhook_url">{{t "alerts.webhook_url_label"}}</label>
            <input id="webhook_url" name="webhook_url" type="url" placeholder="https://example.com/webhooks/search-alerts">
        </div>
        <div class="form-actions">
            <button type="submit" class="btn-primary">{{t "alerts.create_title"}}</button>
            <a href="/search?q={{urlquery .Query}}&category={{.Category}}&safe_search={{.SafeSearch}}" class="btn-secondary">{{t "alerts.back_to_results"}}</a>
        </div>
    </form>
</section>
{{end}}
