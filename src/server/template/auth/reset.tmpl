{{define "content"}}
<div class="auth-page reset-page">
    <div class="auth-container">
        <div class="auth-header">
            <h1>{{t "auth.reset.title"}}</h1>
            <p class="auth-subtitle">{{t "auth.reset.subtitle"}}</p>
        </div>

        {{if .Error}}
        <div class="alert alert-error" role="alert">
            {{.Error}}
        </div>
        {{end}}

        {{if .Success}}
        <div class="alert alert-success" role="alert">
            {{t "auth.reset.success"}}
        </div>
        <div class="auth-footer">
            <a href="/auth/login" class="btn btn-primary btn-block">{{t "auth.reset.sign_in_btn"}}</a>
        </div>
        {{else if eq .Token ""}}
        <div class="alert alert-error" role="alert">
            {{t "auth.reset.invalid_token"}}
        </div>
        <div class="auth-footer">
            <a href="/auth/password/forgot" class="btn btn-secondary btn-block">{{t "auth.reset.request_new_btn"}}</a>
        </div>
        {{else}}
        <form method="POST" action="/auth/password/reset" class="auth-form" id="reset-form">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
            <input type="hidden" name="token" value="{{.Token}}">

            <div class="form-group">
                <label for="password">{{t "auth.reset.new_password_label"}}</label>
                <input type="password" id="password" name="password"
                       autocomplete="new-password" required autofocus
                       placeholder="{{t "auth.reset.password_placeholder"}}" minlength="8">
            </div>

            <div class="form-group">
                <label for="password_confirm">{{t "auth.reset.confirm_password_label"}}</label>
                <input type="password" id="password_confirm" name="password_confirm"
                       autocomplete="new-password" required
                       placeholder="{{t "auth.reset.confirm_placeholder"}}">
            </div>

            <button type="submit" class="btn btn-primary btn-block">
                {{t "auth.reset.submit_btn"}}
            </button>
        </form>

        <div class="auth-footer">
            <a href="/auth/login">{{t "auth.reset.back_to_login"}}</a>
        </div>
        {{end}}
    </div>
</div>
{{/* Per AI.md PART 16: NO inline CSS/JS - all styles in main.css */}}
{{end}}
