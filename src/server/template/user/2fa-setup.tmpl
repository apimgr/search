{{define "content"}}
<div class="user-page twofa-page">
    <div class="page-header">
        <h1>{{t "user.twofa.title"}}</h1>
        <p class="page-subtitle">{{t "user.twofa.subtitle"}}</p>
    </div>

    <div class="user-content">
        {{if .Error}}
        <div class="alert alert-error" role="alert">
            {{.Error}}
        </div>
        {{end}}

        {{if .TwoFASetup}}
        <section class="security-section">
            <h2>{{t "user.twofa.scan_heading"}}</h2>
            <p class="section-description">{{t "user.twofa.scan_description"}}</p>
            <div class="twofa-setup-card">
                <img src="{{.TwoFASetup.QRCodeURL}}" alt="{{t "user.twofa.qr_alt"}}" class="twofa-qr">
                <div class="twofa-setup-details">
                    <dl class="version-grid">
                        <dt>{{t "user.twofa.issuer_label"}}</dt>
                        <dd>{{.TwoFASetup.Issuer}}</dd>
                        <dt>{{t "user.twofa.account_label"}}</dt>
                        <dd>{{.TwoFASetup.Account}}</dd>
                        <dt>{{t "user.twofa.secret_label"}}</dt>
                        <dd><code class="long-string">{{.TwoFASetup.Secret}}</code></dd>
                    </dl>
                </div>
            </div>
        </section>

        <section class="security-section">
            <h2>{{t "user.twofa.verify_heading"}}</h2>
            <form method="POST" action="/users/2fa/setup" class="security-form">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                <input type="hidden" name="step" value="verify">
                <div class="form-group">
                    <label for="twofa_code">{{t "user.twofa.code_label"}}</label>
                    <input type="text" id="twofa_code" name="code" inputmode="numeric" autocomplete="one-time-code" required>
                </div>
                <button type="submit" class="btn btn-primary">{{t "user.twofa.enable_button"}}</button>
            </form>
        </section>
        {{else}}
        <section class="security-section">
            <h2>{{t "user.twofa.confirm_heading"}}</h2>
            <p class="section-description">{{t "user.twofa.confirm_description"}}</p>
            <form method="POST" action="/users/2fa/setup" class="security-form">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">
                <input type="hidden" name="step" value="init">
                <div class="form-group">
                    <label for="setup_password">{{t "user.twofa.password_label"}}</label>
                    <input type="password" id="setup_password" name="password" autocomplete="current-password" required>
                </div>
                <button type="submit" class="btn btn-primary">{{t "user.twofa.continue_button"}}</button>
            </form>
        </section>
        {{end}}
    </div>
</div>
{{end}}
