{{define "content"}}
<div class="user-page recovery-keys-page">
    <div class="page-header">
        <h1>{{t "user.recovery.title"}}</h1>
        <p class="page-subtitle">{{t "user.recovery.subtitle"}}</p>
    </div>

    <div class="user-content">
        {{if .Success}}
        <div class="alert alert-success" role="status">
            {{.Success}}
        </div>
        {{end}}

        <section class="security-section">
            <h2>{{t "user.recovery.heading"}}</h2>
            <p class="section-description">{{t "user.recovery.description"}}</p>
            <ul class="recovery-keys-list">
                {{range .RecoveryKeys}}
                <li class="recovery-key-item"><code class="long-string">{{.}}</code></li>
                {{end}}
            </ul>
            <div class="form-actions">
                <a href="/users/security" class="btn btn-primary">{{t "user.recovery.return_button"}}</a>
            </div>
        </section>
    </div>
</div>
{{end}}
