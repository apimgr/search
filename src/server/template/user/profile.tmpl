{{define "content"}}
<div class="user-page profile-page">
    <div class="page-header">
        <h1>{{t "user.profile.title"}}</h1>
        <p class="page-subtitle">{{t "user.profile.subtitle"}}</p>
    </div>

    <div class="user-container">
        <nav class="user-nav">
            <a href="/users/profile" class="nav-item active">{{t "user.nav.profile"}}</a>
            <a href="/users/security" class="nav-item">{{t "user.nav.security"}}</a>
            <a href="/users/tokens" class="nav-item">{{t "user.nav.tokens"}}</a>
        </nav>

        <div class="user-content">
            {{if .Flash}}
            <div class="alert alert-{{.Flash.Type}}" role="alert">
                {{.Flash.Message}}
            </div>
            {{end}}

            <form method="POST" action="/users/profile" class="profile-form" enctype="multipart/form-data">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}">

                <div class="profile-section">
                    <h2>{{t "user.profile.section_profile_info"}}</h2>

                    <div class="avatar-section">
                        <div class="current-avatar">
                            {{if .User.AvatarURL}}
                            <img src="{{.User.AvatarURL}}" alt="Avatar" class="avatar-img">
                            {{else}}
                            <div class="avatar-placeholder">{{slice .User.Username 0 1 | upper}}</div>
                            {{end}}
                        </div>
                        <div class="avatar-actions">
                            <label class="btn btn-secondary btn-sm">
                                {{t "common.upload"}}
                                <input type="file" name="avatar" accept="image/*" class="hidden">
                            </label>
                            {{if .User.AvatarURL}}
                            <button type="button" class="btn btn-danger btn-sm" name="remove_avatar" value="1">
                                {{t "common.delete"}}
                            </button>
                            {{end}}
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="username">{{t "user.profile.username_label"}}</label>
                            <input type="text" id="username" value="{{.User.Username}}" disabled
                                   class="input-disabled">
                            <small class="form-help">{{t "user.profile.username_help"}}</small>
                        </div>

                        <div class="form-group">
                            <label for="display_name">{{t "user.profile.display_name"}}</label>
                            <input type="text" id="display_name" name="display_name"
                                   value="{{.User.DisplayName}}" maxlength="64"
                                   placeholder="{{.User.Username}}">
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="bio">{{t "user.profile.bio"}}</label>
                        <textarea id="bio" name="bio" rows="3" maxlength="500"
                                  placeholder="{{t "user.profile.bio_placeholder"}}">{{.User.Bio}}</textarea>
                        <small class="form-help char-count"><span id="bio-count">{{len .User.Bio}}</span>/500</small>
                    </div>
                </div>

                <div class="profile-section">
                    <h2>{{t "user.profile.section_email_settings"}}</h2>

                    <div class="form-group">
                        <label for="email">{{t "user.profile.email"}} {{t "user.profile.email_account_suffix"}}</label>
                        <div class="input-with-badge">
                            <input type="email" id="email" name="email" value="{{.User.Email}}" required>
                            {{if .User.EmailVerified}}
                            <span class="badge badge-success">{{t "user.profile.verified"}}</span>
                            {{else}}
                            <span class="badge badge-warning">{{t "user.profile.unverified"}}</span>
                            {{end}}
                        </div>
                        <small class="form-help">{{t "user.profile.email_help"}}</small>
                    </div>

                    <div class="form-group">
                        <label for="notification_email">{{t "user.profile.notification_email_label"}}</label>
                        <div class="input-with-badge">
                            <input type="email" id="notification_email" name="notification_email"
                                   value="{{.User.NotificationEmail}}"
                                   placeholder="{{t "user.profile.notification_email_placeholder"}}">
                            {{if and .User.NotificationEmail .User.NotificationEmailVerified}}
                            <span class="badge badge-success">{{t "user.profile.verified"}}</span>
                            {{else if .User.NotificationEmail}}
                            <span class="badge badge-warning">{{t "user.profile.unverified"}}</span>
                            {{end}}
                        </div>
                        <small class="form-help">{{t "user.profile.notification_email_help"}}</small>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">{{t "form.save"}}</button>
                </div>
            </form>
        </div>
    </div>
</div>
{{/* Per AI.md PART 16: NO inline CSS/JS - all styles in main.css, scripts in app.js */}}
{{end}}
