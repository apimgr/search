{{/* Cookie consent popup partial */}}
{{/* Per AI.md PART 17: No inline JS handlers - use event delegation */}}
{{ define "cookie_consent" }}
{{ if .CookieConsent }}
{{ if .CookieConsent.Enabled }}
<div class="cookie-consent" id="cookie-consent">
    <div class="cookie-consent-content">
        <p class="cookie-consent-message">
            {{ if .CookieConsent.Message }}
                {{ .CookieConsent.Message }}
            {{ else }}
                {{t "cookie_consent.default_message"}}
            {{ end }}
            {{ if .CookieConsent.PolicyURL }}
            <a href="{{ .CookieConsent.PolicyURL }}" class="cookie-consent-link">{{t "cookie_consent.learn_more"}}</a>
            {{ end }}
        </p>
        <div class="cookie-consent-actions">
            <button class="cookie-consent-accept">{{t "common.accept"}}</button>
            <button class="cookie-consent-decline">{{t "common.decline"}}</button>
        </div>
    </div>
</div>
{{/* Per AI.md PART 16: NO inline JS - initialization in app.js */}}
{{ end }}
{{ end }}
{{ end }}
