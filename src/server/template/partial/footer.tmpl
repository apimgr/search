{{define "footer"}}
<footer class="footer">
    {{/* Tor hidden service - per AI.md PART 32 (always show if enabled) */}}
    {{if .TorEnabled}}
    <div class="tor-access">
        <span class="tor-icon">🧅</span>
        {{if .TorAddress}}
        <div class="code-block">
            <code class="code-content onion-address">{{.TorAddress}}</code>
            <button type="button" class="copy-btn" data-copy="{{.TorAddress}}" aria-label="{{t "accessibility.copy_to_clipboard"}}">
                <span class="copy-icon">📋</span>
            </button>
        </div>
        {{else}}
        <span class="tor-status">{{t "footer.tor_status_prefix"}} {{.TorStatus}}</span>
        {{end}}
    </div>
    {{end}}

    {{/* Standard page links (always first) - per AI.md PART 17 */}}
    <p>
        <a href="/server/about">{{t "nav.about"}}</a>
        <span>•</span>
        <a href="/server/privacy">{{t "nav.privacy"}}</a>
        <span>•</span>
        <a href="/server/contact">{{t "nav.contact"}}</a>
        <span>•</span>
        <a href="/server/help">{{t "nav.help"}}</a>
    </p>

    <br />

    {{/* Application branding - per AI.md PART 17 */}}
    <p>
        {{if .Config.Server.Branding.SourceCodeURL}}<a href="{{.Config.Server.Branding.SourceCodeURL}}" target="_blank" rel="noopener">{{t "footer.made_with"}}</a>{{else}}{{t "footer.made_with"}}{{end}} ❤️
        <span>•</span>
        <span>{{version}}</span>
    </p>

    <br />

    <a href="/healthz">{{t "footer.last_update"}} {{.BuildDate}}</a>
</footer>
{{end}}
